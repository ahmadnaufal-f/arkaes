{
  "name": "@arkaes/ui",
  "version": "0.1.0",
  "description": "Framework-agnostic Lit custom elements for the Arkaes design system.",
  "license": "MIT",
  "author": "Ahmad Naufal",
  "homepage": "https://github.com/ahmadnaufal-f/arkaes/tree/main/packages/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadnaufal-f/arkaes.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/ahmadnaufal-f/arkaes/issues"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "lit",
    "design-system",
    "ui",
    "arkaes"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/register.ts",
    "**/register/*.ts",
    "**/register.js",
    "**/register/*.js"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./register": {
      "types": "./src/register.ts",
      "default": "./src/register.ts"
    },
    "./register/*": {
      "types": "./src/register/*.ts",
      "default": "./src/register/*.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "default": "./src/primitives/index.ts"
    },
    "./primitives/*": {
      "types": "./src/primitives/*.ts",
      "default": "./src/primitives/*.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.ts",
      "default": "./src/components/*.ts"
    },
    "./patterns": {
      "types": "./src/patterns/index.ts",
      "default": "./src/patterns/index.ts"
    },
    "./patterns/*": {
      "types": "./src/patterns/*.ts",
      "default": "./src/patterns/*.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./react/*": {
      "types": "./src/react/*.ts",
      "default": "./src/react/*.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./register": {
        "types": "./dist/register.d.ts",
        "default": "./dist/register.js"
      },
      "./register/*": {
        "types": "./dist/register/*.d.ts",
        "default": "./dist/register/*.js"
      },
      "./primitives": {
        "types": "./dist/primitives/index.d.ts",
        "default": "./dist/primitives/index.js"
      },
      "./primitives/*": {
        "types": "./dist/primitives/*.d.ts",
        "default": "./dist/primitives/*.js"
      },
      "./components": {
        "types": "./dist/components/index.d.ts",
        "default": "./dist/components/index.js"
      },
      "./components/*": {
        "types": "./dist/components/*.d.ts",
        "default": "./dist/components/*.js"
      },
      "./patterns": {
        "types": "./dist/patterns/index.d.ts",
        "default": "./dist/patterns/index.js"
      },
      "./patterns/*": {
        "types": "./dist/patterns/*.d.ts",
        "default": "./dist/patterns/*.js"
      },
      "./react": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "./react/*": {
        "types": "./dist/react/*.d.ts",
        "default": "./dist/react/*.js"
      }
    }
  },
  "scripts": {
    "build": "tsdown && node ./scripts/postbuild-use-client.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@arkaes/tokens": "workspace:^",
    "@lit/react": "^1.0.8",
    "lit": "^3.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.3"
  }
}
