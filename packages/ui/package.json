{
  "name": "@arkaes/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "src/**/*.css",
    "src/register.ts",
    "src/register/*.ts"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./register": {
      "types": "./src/register.ts",
      "default": "./src/register.ts"
    },
    "./register/*": {
      "types": "./src/register/*.ts",
      "default": "./src/register/*.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "default": "./src/primitives/index.ts"
    },
    "./primitives/*": {
      "types": "./src/primitives/*.ts",
      "default": "./src/primitives/*.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.ts",
      "default": "./src/components/*.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@arkaes/tokens": "workspace:*",
    "lit": "^3.3.0"
  }
}
