{
  "name": "arkaes",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "yaml-language-server@1.20.0>yaml": "2.9.0",

      "esbuild": "^0.28.1",
      "@eslint/eslintrc>js-yaml": "^4.2.0",
      "@astrojs/internal-helpers>js-yaml": "^4.2.0"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "dev": "turbo dev",
    "dev:storybook": "pnpm --filter storybook dev",
    "dev:portfolio": "pnpm --filter portfolio dev",
    "format": "eslint . --fix",
    "lint": "turbo lint",
    "test": "turbo test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=@arkaes/tokens --filter=@arkaes/ui && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.25.1",
    "@stylistic/eslint-plugin": "^4.2.0",
    "eslint": "^9.25.1",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
}
