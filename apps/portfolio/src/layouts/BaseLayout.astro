---
import { ClientRouter, fade } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "lenis/dist/lenis.css";
import "../styles/global.css";

interface Props {
  description?: string;
  title?: string;
}

const {
  description = "A performance-first portfolio powered by Astro and a small Lit-based design system.",
  title = "Arkaes Portfolio",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400&family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <div
      class="cursor"
      id="cursor"
      aria-hidden="true"
      transition:persist="ark-cursor"
    >
    </div>
    <div
      class="cursor-ring"
      id="cursorRing"
      aria-hidden="true"
      transition:persist="ark-cursor-ring"
    >
    </div>

    <SiteHeader />
    <main id="top" transition:animate={fade({ duration: "0.42s" })}>
      <slot />
    </main>
    <SiteFooter />

    <script>
      // Register the full custom-element set once for the document lifetime so
      // elements stay defined across client-side View Transitions navigations.
      import "@arkaes/ui/register";
      import Lenis from "lenis";

      // ── Persistent setup (runs once for the document lifetime) ──────────
      const canUseCursor = window.matchMedia(
        "(hover: hover) and (pointer: fine)",
      ).matches;
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      // ── Lenis smooth scroll ──────────────────────
      const lenis = reduceMotion ? null : new Lenis({ autoRaf: true, anchors: true });

      if (lenis) {
        // View Transitions keep the document alive, so re-sync Lenis to the
        // new page's scroll position (hash target or top) after each swap,
        // otherwise it would lerp back toward the previous page's offset.
        document.addEventListener("astro:after-swap", () => {
          const target = window.location.hash
            ? document.querySelector<HTMLElement>(window.location.hash)
            : null;
          lenis.scrollTo(target ?? 0, { immediate: true });
        });
      }

      const scrollToTop = () => {
        if (lenis) {
          lenis.scrollTo(0);
        } else {
          window.scrollTo({ top: 0, behavior: reduceMotion ? "auto" : "smooth" });
        }
      };

      if (canUseCursor) {
        const cursor = document.getElementById("cursor");
        const ring = document.getElementById("cursorRing");

        if (cursor && ring) {
          let mouseX = 0;
          let mouseY = 0;
          let ringX = 0;
          let ringY = 0;

          document.addEventListener("mousemove", (event) => {
            mouseX = event.clientX;
            mouseY = event.clientY;
            cursor.style.left = `${mouseX}px`;
            cursor.style.top = `${mouseY}px`;
          });

          const animateRing = () => {
            ringX += (mouseX - ringX) * 0.12;
            ringY += (mouseY - ringY) * 0.12;
            ring.style.left = `${ringX}px`;
            ring.style.top = `${ringY}px`;
            requestAnimationFrame(animateRing);
          };

          animateRing();
        }

        const interactiveSelector =
          "a[href], button, ark-button, ark-card, ark-case-study-card";
        document.addEventListener("pointerover", (event) => {
          const overInteractive = event
            .composedPath()
            .some(
              (node) =>
                node instanceof Element && node.matches(interactiveSelector),
            );
          document.body.classList.toggle("hovering", overInteractive);
        });
      }

      // ── Per-page setup (runs on first load and after every navigation) ──
      const initPage = () => {
        document.body.classList.remove("hovering");

        if (canUseCursor) {
          document.documentElement.dataset.customCursor = "";
        }

        const reveals = document.querySelectorAll(".reveal");
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08 },
        );
        reveals.forEach((element) => observer.observe(element));

        document.querySelectorAll<HTMLElement>("[data-scroll-top]").forEach(
          (element) => {
            element.addEventListener("click", (event) => {
              event.preventDefault();
              scrollToTop();
            });
          },
        );
      };

      document.addEventListener("astro:page-load", initPage);
    </script>
  </body>
</html>
