---
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { fadeThroughBlank } from "../transitions/fade-through-blank";
import "../styles/global.css";

interface Props {
  description?: string;
  title?: string;
}

const {
  description = "A performance-first portfolio powered by Astro and a small Lit-based design system.",
  title = "Arkaes Portfolio",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <meta name="theme-color" content="#8f554d" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400&family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <Analytics />
    <ClientRouter />
    <title>{title}</title>
    <style>
      #page-loader {
        align-items: center;
        background: var(--ark-color-bg, #fbf8f3);
        display: flex;
        inset: 0;
        justify-content: center;
        opacity: 1;
        pointer-events: all;
        position: fixed;
        transition: opacity 300ms var(--ark-ease-standard, cubic-bezier(0.2, 0, 0, 1));
        z-index: 9999;
      }
      #page-loader.page-loader--done {
        opacity: 0;
        pointer-events: none;
      }
      @keyframes page-loader-spin {
        to {
          transform: rotate(360deg);
        }
      }
      .page-loader-spinner {
        animation: page-loader-spin 0.9s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        border-color: transparent;
        border-radius: 50%;
        border-style: solid;
        border-top-color: var(--ark-color-accent, #8f554d);
        border-right-color: color-mix(
          in srgb,
          var(--ark-color-accent, #8f554d) 33%,
          transparent
        );
        border-width: 2px;
        display: inline-block;
        height: 36px;
        width: 36px;
      }
      @media (prefers-reduced-motion: reduce) {
        #page-loader {
          transition: none;
        }
        .page-loader-spinner {
          animation: none;
        }
      }
    </style>
  </head>
  <body>
    <div id="page-loader" aria-hidden="true">
      <span class="page-loader-spinner"></span>
    </div>
    <SiteHeader />
    <main id="top" transition:animate={fadeThroughBlank}>
      <slot />
    </main>
    <SiteFooter />

    <script>
      // Register the full custom-element set once for the document lifetime so
      // elements stay defined across client-side View Transitions navigations.
      import "@arkaes/ui/register";
      import { enableArkCursor } from "@arkaes/ui/components/ark-cursor";
      import type { ArkButton } from "@arkaes/ui";
      import type { ArkNavLink, ArkNavigationCta } from "@arkaes/ui";

      // ── Persistent setup (runs once for the document lifetime) ──────────
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      // Custom cursor — the component owns the dot/ring, native-cursor hiding,
      // hover detection (across shadow DOM), capability gating, and View
      // Transition persistence. See @arkaes/ui.
      enableArkCursor();

      // Before the DOM swap, close any open dialogs so their portal containers
      // don't linger on the body after navigation.
      document.addEventListener("astro:before-swap", () => {
        document
          .querySelectorAll<
            HTMLElement & { open: boolean }
          >("ark-dialog-root[open]")
          .forEach((root) => {
            root.open = false;
          });
      });

      // Activate the loading/navigating state on the clicked link element as
      // soon as the user clicks, so there is immediate feedback while
      // Astro's ClientRouter fetches the next page in the background.
      const NAV_TAGS = new Set(["ARK-BUTTON", "ARK-NAV-LINK", "ARK-NAVIGATION-CTA"]);
      let pendingNavEls: Element[] = [];

      document.addEventListener("click", (e) => {
        if (e.button !== 0 || e.ctrlKey || e.metaKey || e.shiftKey || e.altKey) return;

        const path = e.composedPath();

        const anchor = path.find((el): el is HTMLAnchorElement => el instanceof HTMLAnchorElement);
        if (!anchor?.href || (anchor.target && anchor.target !== "_self")) return;

        let url: URL;
        try {
          url = new URL(anchor.href);
        } catch {
          return;
        }

        // Only same-origin navigations that actually load a different page.
        // Hash-only changes (same pathname) are instant scroll — no loading needed.
        if (url.origin !== location.origin || url.pathname === location.pathname) return;

        const host = path.find((el): el is Element => el instanceof Element && NAV_TAGS.has(el.tagName));
        if (!host) return;

        if (host.tagName === "ARK-BUTTON") {
          (host as ArkButton).loading = true;
        } else {
          (host as ArkNavLink | ArkNavigationCta).navigating = true;
        }
        pendingNavEls.push(host);
      });

      // Clear all loading/navigating states just before the DOM swap —
      // the transition animation takes over as visual feedback from here.
      document.addEventListener("astro:before-swap", () => {
        pendingNavEls.forEach((el) => {
          if (el.tagName === "ARK-BUTTON") {
            (el as ArkButton).loading = false;
          } else {
            (el as ArkNavLink | ArkNavigationCta).navigating = false;
          }
        });
        pendingNavEls = [];
      });

      const scrollToTop = () => {
        window.scrollTo({
          top: 0,
          behavior: reduceMotion ? "auto" : "smooth",
        });
      };

      // ── Per-page setup (runs on first load and after every navigation) ──
      const initPage = () => {
        const loader = document.getElementById("page-loader");
        if (loader) {
          loader.classList.add("page-loader--done");
          setTimeout(() => loader.remove(), 350);
        }

        const reveals = document.querySelectorAll(".reveal");
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08 },
        );
        reveals.forEach((element) => observer.observe(element));

        document
          .querySelectorAll<HTMLElement>("[data-scroll-top]")
          .forEach((element) => {
            element.addEventListener("click", (event) => {
              event.preventDefault();
              scrollToTop();
            });
          });
      };

      document.addEventListener("astro:page-load", initPage);
    </script>
  </body>
</html>
