---
interface Props {
  transitionName: string;
  asSlot?: string;
}
const { transitionName, asSlot } = Astro.props;
---

<div
  class="thumb-air"
  slot={asSlot}
  style={`view-transition-name: ${transitionName};`}
>
  <div class="thumb-air-panel">
    <div class="thumb-air-topbar">
      <div class="thumb-air-dot"></div>
      <div class="thumb-air-topbar-label"></div>
    </div>
    <div class="thumb-air-gauge-wrap">
      <div class="thumb-air-gauge">
        <div class="thumb-air-gauge-ring"></div>
        <div class="thumb-air-gauge-inner">
          <div class="thumb-air-gauge-value"></div>
          <div class="thumb-air-gauge-unit"></div>
        </div>
      </div>
    </div>
    <div class="thumb-air-devices">
      <div class="thumb-air-device thumb-air-device--active">
        <div class="thumb-air-device-icon">
          <div class="thumb-air-device-fan"></div>
        </div>
        <div class="thumb-air-device-label"></div>
      </div>
      <div class="thumb-air-device">
        <div class="thumb-air-device-icon thumb-air-device-icon--dim">
          <div class="thumb-air-device-bars">
            <div></div>
            <div></div>
            <div></div>
          </div>
        </div>
        <div class="thumb-air-device-label"></div>
      </div>
      <div class="thumb-air-device">
        <div class="thumb-air-device-icon thumb-air-device-icon--dim">
          <div class="thumb-air-device-drop"></div>
        </div>
        <div class="thumb-air-device-label"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .thumb-air {
    align-items: center;
    background: var(--thumbnail-background, var(--ark-color-accent-soft));
    display: flex;
    height: var(--thumbnail-height, auto);
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .thumb-air-panel {
    background: var(--ark-color-surface);
    border: 1px solid var(--ark-color-border);
    border-radius: 20px;
    box-shadow: var(--ark-shadow-md);
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    width: 192px;
  }

  .thumb-air-topbar {
    align-items: center;
    display: flex;
    gap: 8px;
  }

  .thumb-air-dot {
    background: color-mix(in srgb, var(--ark-color-accent) 70%, transparent);
    border-radius: 50%;
    height: 8px;
    width: 8px;
  }

  .thumb-air-topbar-label {
    background: var(--ark-color-neutral-200);
    border-radius: 3px;
    height: 6px;
    width: 72px;
  }

  .thumb-air-gauge-wrap {
    align-items: center;
    background: var(--ark-color-neutral-50);
    border: 1px solid var(--ark-color-border);
    border-radius: 14px;
    display: flex;
    justify-content: center;
    padding: 18px 0 14px;
  }

  .thumb-air-gauge {
    align-items: center;
    display: flex;
    justify-content: center;
    position: relative;
  }

  .thumb-air-gauge-ring {
    border: 6px solid var(--ark-color-accent-soft);
    border-radius: 50%;
    border-top-color: var(--ark-color-accent);
    border-right-color: var(--ark-color-accent);
    height: 56px;
    width: 56px;
  }

  .thumb-air-gauge-inner {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: 2px;
    inset: 0;
    justify-content: center;
    position: absolute;
  }

  .thumb-air-gauge-value {
    background: color-mix(in srgb, var(--ark-color-accent) 60%, transparent);
    border-radius: 3px;
    height: 10px;
    width: 24px;
  }

  .thumb-air-gauge-unit {
    background: var(--ark-color-neutral-200);
    border-radius: 2px;
    height: 6px;
    width: 16px;
  }

  .thumb-air-devices {
    display: flex;
    gap: 6px;
  }

  .thumb-air-device {
    align-items: center;
    background: var(--ark-color-neutral-50);
    border: 1px solid var(--ark-color-border);
    border-radius: 10px;
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 7px;
    padding: 10px 6px 8px;
  }

  .thumb-air-device--active {
    background: var(--ark-color-accent-soft);
    border-color: color-mix(in srgb, var(--ark-color-accent) 40%, transparent);
  }

  .thumb-air-device-icon {
    align-items: center;
    border-radius: 50%;
    display: flex;
    height: 26px;
    justify-content: center;
    width: 26px;
    background: var(--ark-color-accent);
  }

  .thumb-air-device-icon--dim {
    background: var(--ark-color-neutral-200);
  }

  .thumb-air-device-fan {
    border: 2px solid var(--ark-color-surface);
    border-radius: 50%;
    height: 12px;
    position: relative;
    width: 12px;
  }

  .thumb-air-device-fan::before,
  .thumb-air-device-fan::after {
    background: var(--ark-color-surface);
    border-radius: 2px;
    content: "";
    height: 5px;
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 2px;
  }

  .thumb-air-device-fan::after {
    height: 2px;
    width: 5px;
  }

  .thumb-air-device-bars {
    display: flex;
    gap: 2px;
    align-items: flex-end;
    height: 12px;
  }

  .thumb-air-device-bars > div {
    background: var(--ark-color-surface);
    border-radius: 1px;
    width: 3px;
  }

  .thumb-air-device-bars > div:nth-child(1) { height: 5px; }
  .thumb-air-device-bars > div:nth-child(2) { height: 9px; }
  .thumb-air-device-bars > div:nth-child(3) { height: 12px; }

  .thumb-air-device-drop {
    background: var(--ark-color-surface);
    border-radius: 50% 50% 50% 0;
    height: 10px;
    transform: rotate(45deg);
    width: 10px;
  }

  .thumb-air-device-label {
    background: var(--ark-color-neutral-200);
    border-radius: 2px;
    height: 5px;
    width: 80%;
  }
</style>
