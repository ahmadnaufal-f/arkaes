---
interface Props {
  transitionName: string;
  asSlot?: string;
}
const { transitionName, asSlot } = Astro.props;

// Tells the case study's headline at a glance: two product variants — a mobile
// app (phone) and the Family Hub fridge screen (wide display) — both wired down
// into one shared monorepo foundation (±87% shared code).
type Tile = { x: number; y: number; on?: boolean; alt?: boolean };
const gridTiles: Tile[] = [
  { x: 132, y: 48 },
  { x: 156, y: 48, on: true },
  { x: 180, y: 48 },
  { x: 132, y: 66 },
  { x: 156, y: 66 },
  { x: 180, y: 66, alt: true },
];

type Module = { x: number; alt?: boolean };
const modules: Module[] = [{ x: 46 }, { x: 98, alt: true }, { x: 150 }];
---

<div
  class="thumb-vhome"
  slot={asSlot}
  style={`view-transition-name: ${transitionName};`}
>
  <div class="thumb-vhome-card">
    <svg
      class="thumb-vhome-svg"
      viewBox="0 0 240 188"
      role="img"
      aria-label="Two product variants — a mobile app and a Family Hub screen — built on one shared monorepo foundation"
    >
      <!-- Connectors: each variant wired down to the shared foundation -->
      <g class="vh-links" fill="none">
        <path d="M69 96 C69 110 96 116 120 120" />
        <path d="M160 90 C160 108 142 114 120 120" />
        <path class="vh-link--static" d="M120 124 V134" />
      </g>
      <circle class="vh-node-halo" cx="120" cy="120" r="9" />
      <circle class="vh-node" cx="120" cy="120" r="5" />
      <circle class="vh-dot" cx="69" cy="96" r="2.5" />
      <circle class="vh-dot" cx="160" cy="90" r="2.5" />

      <!-- Shared monorepo foundation -->
      <rect class="vh-platform-base" x="34" y="140" width="176" height="40" rx="12" />
      <rect class="vh-platform" x="32" y="134" width="176" height="40" rx="12" />
      <rect class="vh-heading" x="46" y="142" width="28" height="3" rx="1.5" />
      {
        modules.map((m) => (
          <g class={m.alt ? "vh-module vh-module--alt" : "vh-module"}>
            <rect class="vh-module-bg" x={m.x} y="152" width="44" height="15" rx="4" />
            <circle class="vh-module-dot" cx={m.x + 8} cy="159.5" r="2.5" />
            <rect class="vh-module-line" x={m.x + 16} y="158" width="20" height="3" rx="1.5" />
          </g>
        ))
      }

      <!-- Mobile variant -->
      <rect class="vh-device" x="46" y="16" width="46" height="80" rx="9" />
      <rect class="vh-screen" x="50" y="22" width="38" height="68" rx="5" />
      <polygon class="vh-house" points="58,44 69,34 80,44" />
      <rect class="vh-house" x="61" y="44" width="16" height="15" rx="1.5" />
      <rect class="vh-window" x="66" y="48" width="6" height="6" rx="1" />
      <rect class="vh-toggle" x="54" y="68" width="30" height="11" rx="5.5" />
      <circle class="vh-knob" cx="78" cy="73.5" r="4" />
      <path class="vh-line" d="M54 85 H72" />

      <!-- Family Hub fridge-screen variant -->
      <rect class="vh-device" x="112" y="26" width="96" height="64" rx="8" />
      <rect class="vh-handle" x="117" y="42" width="3" height="32" rx="1.5" />
      <rect class="vh-screen" x="126" y="32" width="76" height="52" rx="5" />
      <path class="vh-line" d="M132 39 H160" />
      <circle class="vh-dot vh-dot--soft" cx="190" cy="39" r="1.6" />
      <circle class="vh-dot vh-dot--soft" cx="196" cy="39" r="1.6" />
      {
        gridTiles.map((t) => (
          <rect
            class={`vh-tile${t.on ? " vh-tile--on" : ""}${t.alt ? " vh-tile--alt" : ""}`}
            x={t.x}
            y={t.y}
            width="20"
            height="13"
            rx="3"
          />
        ))
      }
    </svg>
  </div>
</div>

<style>
  .thumb-vhome {
    align-items: center;
    background: var(--thumbnail-background, var(--ark-color-accent-soft));
    display: flex;
    height: var(--thumbnail-height, auto);
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  /* Centered card, smaller than the container, so its shadow never clips. */
  .thumb-vhome-card {
    background: var(--ark-color-surface);
    border: 1px solid var(--ark-color-border);
    border-radius: 20px;
    box-shadow: var(--ark-shadow-md);
    padding: 14px 16px;
    width: 250px;
  }

  .thumb-vhome-svg {
    display: block;
    height: auto;
    width: 100%;
  }

  /* ── Connectors / shared-code flow ── */
  .vh-links path {
    stroke: color-mix(in srgb, var(--ark-color-accent) 50%, transparent);
    stroke-linecap: round;
    stroke-width: 1.6;
  }

  .vh-links path:not(.vh-link--static) {
    stroke-dasharray: 4 6;
  }

  .vh-node {
    fill: var(--ark-color-accent);
  }

  .vh-node-halo {
    fill: color-mix(in srgb, var(--ark-color-accent) 18%, transparent);
  }

  .vh-dot {
    fill: var(--ark-color-accent);
  }

  .vh-dot--soft {
    fill: color-mix(in srgb, var(--ark-color-accent) 45%, transparent);
  }

  /* ── Shared foundation ── */
  .vh-platform-base {
    fill: color-mix(in srgb, var(--ark-color-accent) 22%, transparent);
  }

  .vh-platform {
    fill: var(--ark-color-surface);
    stroke: color-mix(in srgb, var(--ark-color-accent) 42%, transparent);
    stroke-width: 1.5;
  }

  .vh-heading {
    fill: var(--ark-color-accent);
  }

  .vh-module-bg {
    fill: var(--ark-color-accent-soft);
    stroke: color-mix(in srgb, var(--ark-color-accent) 40%, transparent);
    stroke-width: 1;
  }

  .vh-module-dot {
    fill: var(--ark-color-accent);
  }

  .vh-module-line {
    fill: color-mix(in srgb, var(--ark-color-accent) 35%, transparent);
  }

  .vh-module--alt .vh-module-bg {
    fill: var(--ark-color-secondary-soft);
    stroke: color-mix(in srgb, var(--ark-color-secondary) 42%, transparent);
  }

  .vh-module--alt .vh-module-dot {
    fill: var(--ark-color-secondary);
  }

  .vh-module--alt .vh-module-line {
    fill: color-mix(in srgb, var(--ark-color-secondary) 38%, transparent);
  }

  /* ── Device bodies ── */
  .vh-device {
    fill: var(--ark-color-surface);
    stroke: color-mix(in srgb, var(--ark-color-accent) 42%, transparent);
    stroke-width: 1.5;
  }

  .vh-screen {
    fill: var(--ark-color-neutral-50);
  }

  .vh-handle {
    fill: color-mix(in srgb, var(--ark-color-accent) 48%, transparent);
  }

  /* ── Mobile content ── */
  .vh-house {
    fill: var(--ark-color-accent);
  }

  .vh-window {
    fill: var(--ark-color-secondary);
  }

  .vh-toggle {
    fill: var(--ark-color-accent-soft);
    stroke: color-mix(in srgb, var(--ark-color-accent) 45%, transparent);
    stroke-width: 1;
  }

  .vh-knob {
    fill: var(--ark-color-accent);
  }

  .vh-line {
    fill: none;
    stroke: var(--ark-color-neutral-300);
    stroke-linecap: round;
    stroke-width: 2;
  }

  /* ── Family Hub grid ── */
  .vh-tile {
    fill: var(--ark-color-neutral-100);
    stroke: color-mix(in srgb, var(--ark-color-accent) 16%, transparent);
    stroke-width: 1;
  }

  .vh-tile--on {
    fill: var(--ark-color-accent-soft);
    stroke: color-mix(in srgb, var(--ark-color-accent) 55%, transparent);
  }

  .vh-tile--alt {
    fill: var(--ark-color-secondary-soft);
    stroke: color-mix(in srgb, var(--ark-color-secondary) 48%, transparent);
  }

  /* ── Motion: shared code flowing down the connectors ── */
  @media (prefers-reduced-motion: no-preference) {
    .vh-links path:not(.vh-link--static) {
      animation: vh-flow 1.8s linear infinite;
    }

    .vh-node-halo {
      animation: vh-pulse 2.6s ease-in-out infinite;
      transform-box: fill-box;
      transform-origin: center;
    }
  }

  @keyframes vh-flow {
    to {
      stroke-dashoffset: -20;
    }
  }

  @keyframes vh-pulse {
    0%,
    100% {
      opacity: 0.5;
      transform: scale(0.85);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }
</style>
