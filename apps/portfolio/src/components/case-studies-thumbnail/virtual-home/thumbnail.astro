---
interface Props {
  transitionName: string;
  asSlot?: string;
}
const { transitionName, asSlot } = Astro.props;

// Two product variants — a mobile app (phone) and the Family Hub screen (wide
// display) — resting on one shared monorepo foundation. Kept deliberately
// minimal: a couple of clean device shapes, two links, and a base.
type Tile = { x: number; y: number; on?: boolean; alt?: boolean };
const tiles: Tile[] = [
  { x: 130, y: 42 },
  { x: 164, y: 42, on: true },
  { x: 130, y: 64, alt: true },
  { x: 164, y: 64 },
];
const pills = [{ x: 52 }, { x: 100, alt: true }, { x: 148 }];
---

<div
  class="thumb-vhome"
  slot={asSlot}
  style={`view-transition-name: ${transitionName};`}
>
  <div class="thumb-vhome-card">
    <svg
      class="thumb-vhome-svg"
      viewBox="0 0 240 180"
      role="img"
      aria-label="A mobile app and a Family Hub screen resting on one shared foundation"
    >
      <!-- Links from each variant down to the shared foundation -->
      <g class="vh-links" fill="none">
        <path d="M74 96 C74 108 100 116 118 120" />
        <path d="M162 90 C162 106 138 114 118 120" />
      </g>
      <circle class="vh-node" cx="118" cy="121" r="4" />

      <!-- Shared monorepo foundation -->
      <rect class="vh-base" x="42" y="132" width="156" height="32" rx="10" />
      <rect class="vh-slab" x="40" y="126" width="156" height="32" rx="10" />
      {
        pills.map((p) => (
          <rect
            class={p.alt ? "vh-pill vh-pill--alt" : "vh-pill"}
            x={p.x}
            y="138"
            width="40"
            height="8"
            rx="4"
          />
        ))
      }

      <!-- Mobile variant -->
      <rect class="vh-device" x="52" y="18" width="44" height="78" rx="9" />
      <rect class="vh-screen" x="56" y="24" width="36" height="66" rx="5" />
      <polygon class="vh-house" points="62,55 74,47 86,55" />
      <rect class="vh-house" x="66" y="55" width="16" height="17" rx="2" />
      <rect class="vh-window" x="71" y="60" width="6" height="7" rx="1" />

      <!-- Family Hub screen variant -->
      <rect class="vh-device" x="116" y="30" width="92" height="60" rx="8" />
      <rect class="vh-screen" x="124" y="36" width="76" height="48" rx="5" />
      {
        tiles.map((t) => (
          <rect
            class={`vh-tile${t.on ? " vh-tile--on" : ""}${t.alt ? " vh-tile--alt" : ""}`}
            x={t.x}
            y={t.y}
            width="30"
            height="18"
            rx="3"
          />
        ))
      }
    </svg>
  </div>
</div>

<style>
  .thumb-vhome {
    align-items: center;
    background: var(--thumbnail-background, var(--ark-color-accent-soft));
    display: flex;
    height: var(--thumbnail-height, auto);
    justify-content: center;
    position: relative;
  }

  /* Centered card, smaller than the container, so its shadow never clips. */
  .thumb-vhome-card {
    background: var(--ark-color-surface);
    border: 1px solid var(--ark-color-border);
    border-radius: 20px;
    box-shadow: var(--ark-shadow-md);
    padding: 14px 16px;
    width: 250px;
  }

  .thumb-vhome-svg {
    display: block;
    height: auto;
    width: 100%;
  }

  /* ── Links ── */
  .vh-links path {
    stroke: color-mix(in srgb, var(--ark-color-accent) 45%, transparent);
    stroke-dasharray: 4 6;
    stroke-linecap: round;
    stroke-width: 1.6;
  }

  .vh-node {
    fill: var(--ark-color-accent);
  }

  /* ── Shared foundation ── */
  .vh-base {
    fill: color-mix(in srgb, var(--ark-color-accent) 20%, transparent);
  }

  .vh-slab {
    fill: var(--ark-color-surface);
    stroke: color-mix(in srgb, var(--ark-color-accent) 42%, transparent);
    stroke-width: 1.5;
  }

  .vh-pill {
    fill: var(--ark-color-accent-soft);
  }

  .vh-pill--alt {
    fill: var(--ark-color-secondary-soft);
  }

  /* ── Device bodies ── */
  .vh-device {
    fill: var(--ark-color-surface);
    stroke: color-mix(in srgb, var(--ark-color-accent) 42%, transparent);
    stroke-width: 1.5;
  }

  .vh-screen {
    fill: var(--ark-color-neutral-50);
  }

  /* ── Mobile content ── */
  .vh-house {
    fill: var(--ark-color-accent-soft);
  }

  .vh-window {
    fill: color-mix(in srgb, var(--ark-color-accent) 38%, transparent);
  }

  /* ── Family Hub grid ── */
  .vh-tile {
    fill: var(--ark-color-neutral-100);
    stroke: color-mix(in srgb, var(--ark-color-accent) 16%, transparent);
    stroke-width: 1;
  }

  .vh-tile--on {
    fill: var(--ark-color-accent-soft);
    stroke: color-mix(in srgb, var(--ark-color-accent) 52%, transparent);
  }

  .vh-tile--alt {
    fill: var(--ark-color-secondary-soft);
    stroke: color-mix(in srgb, var(--ark-color-secondary) 46%, transparent);
  }

  /* ── Motion: subtle shared-code flow down the links ── */
  @media (prefers-reduced-motion: no-preference) {
    .vh-links path {
      animation: vh-flow 1.8s linear infinite;
    }
  }

  @keyframes vh-flow {
    to {
      stroke-dashoffset: -20;
    }
  }
</style>
