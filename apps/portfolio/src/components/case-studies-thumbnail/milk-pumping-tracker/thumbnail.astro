---
interface Props {
  transitionName: string;
  asSlot?: string;
}
const { transitionName, asSlot } = Astro.props;
---

<div
  class="thumb-milk"
  slot={asSlot}
  style={`view-transition-name: ${transitionName};`}
>
  <div class="thumb-milk-phone">
    <div class="thumb-milk-greet">
      <div class="thumb-milk-greet-line thumb-milk-greet-line--lg"></div>
      <div class="thumb-milk-greet-line"></div>
    </div>
    <div class="thumb-milk-session">
      <div class="thumb-milk-bottle">
        <div class="thumb-milk-bottle-cap"></div>
        <div class="thumb-milk-bottle-neck"></div>
        <div class="thumb-milk-bottle-body">
          <div class="thumb-milk-bottle-fill"></div>
        </div>
      </div>
    </div>
    <div class="thumb-milk-timer">
      <div class="thumb-milk-timer-dot"></div>
      <div class="thumb-milk-timer-bar"></div>
    </div>
  </div>
</div>

<style>
  .thumb-milk {
    align-items: center;
    background: var(--thumbnail-background, var(--ark-color-accent-soft));
    display: flex;
    height: var(--thumbnail-height, auto);
    justify-content: center;
    overflow: visible;
    position: relative;
  }

  .thumb-milk-phone {
    background: var(--ark-color-surface);
    border: 1px solid var(--ark-color-border);
    border-radius: 20px;
    box-shadow: var(--ark-shadow-md);
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 18px 16px;
    width: 184px;
  }

  .thumb-milk-greet {
    background: var(--ark-color-neutral-50);
    border: 1px solid var(--ark-color-border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 14px;
  }

  .thumb-milk-greet-line {
    background: color-mix(in srgb, var(--ark-color-accent) 22%, transparent);
    border-radius: 3px;
    height: 6px;
    width: 60%;
  }

  .thumb-milk-greet-line--lg {
    background: color-mix(in srgb, var(--ark-color-accent) 50%, transparent);
    height: 8px;
    width: 80%;
  }

  .thumb-milk-session {
    align-items: center;
    background: var(--ark-color-neutral-50);
    border: 1px solid var(--ark-color-border);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding: 22px 0;
  }

  .thumb-milk-bottle {
    align-items: center;
    display: flex;
    flex-direction: column;
  }

  .thumb-milk-bottle-cap {
    background: var(--ark-color-accent);
    border-radius: 3px 3px 0 0;
    height: 9px;
    width: 22px;
  }

  .thumb-milk-bottle-neck {
    background: color-mix(in srgb, var(--ark-color-accent) 60%, transparent);
    height: 5px;
    width: 16px;
  }

  .thumb-milk-bottle-body {
    background: var(--ark-color-accent-soft);
    border: 1.5px solid var(--ark-color-accent);
    border-radius: 6px 6px 9px 9px;
    height: 54px;
    overflow: hidden;
    position: relative;
    width: 38px;
  }

  .thumb-milk-bottle-fill {
    background: color-mix(
      in srgb,
      var(--ark-color-accent) 32%,
      var(--ark-color-accent-soft)
    );
    bottom: 0;
    height: 58%;
    left: 0;
    position: absolute;
    width: 100%;
  }

  .thumb-milk-timer {
    align-items: center;
    background: var(--ark-color-neutral-50);
    border: 1px solid var(--ark-color-border);
    border-radius: 999px;
    display: flex;
    gap: 8px;
    padding: 9px 14px;
  }

  .thumb-milk-timer-dot {
    background: var(--ark-color-accent);
    border-radius: 50%;
    height: 8px;
    width: 8px;
  }

  .thumb-milk-timer-bar {
    background: var(--ark-color-neutral-200);
    border-radius: 3px;
    flex: 1;
    height: 6px;
  }
</style>
