---
// Knowledge admin UI. Server-rendered and gated by the Basic Auth middleware
// (src/middleware.ts) — set ADMIN_PASSWORD to enable. Standalone layout so the
// chatbot widget and site chrome don't load here.
import { ragConfigured } from "@/lib/rag";
import "./_knowledge.css";

export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Knowledge admin · Arkhe</title>
    <style>
      body {
        background: var(--ark-color-bg);
        color: var(--ark-color-text);
        font-family: var(--ark-font-sans);
        line-height: var(--ark-leading-normal);
        margin: 0;
        padding: var(--ark-space-6);
      }
      main {
        margin: 0 auto;
        max-width: 720px;
      }
      h1 {
        font-size: var(--ark-text-xl, 1.5rem);
        margin: 0 0 var(--ark-space-2);
      }
      p.lede {
        color: var(--ark-color-text-muted);
        margin: 0 0 var(--ark-space-6);
      }
      fieldset {
        border: 1px solid var(--ark-color-border);
        border-radius: var(--ark-radius-md);
        margin: 0 0 var(--ark-space-6);
        padding: var(--ark-space-4);
      }
      legend {
        font-weight: var(--ark-weight-semibold);
        padding: 0 var(--ark-space-2);
      }
      label {
        display: block;
        font-size: var(--ark-text-sm);
        font-weight: var(--ark-weight-medium, 500);
        margin: 0 0 var(--ark-space-1);
      }
      .field {
        margin-bottom: var(--ark-space-4);
      }
      input[type="text"],
      textarea {
        background: var(--ark-color-surface);
        border: 1px solid var(--ark-color-border);
        border-radius: var(--ark-radius-sm, 6px);
        box-sizing: border-box;
        color: var(--ark-color-text);
        font: inherit;
        padding: var(--ark-space-2) var(--ark-space-3);
        width: 100%;
      }
      textarea {
        min-height: 8rem;
        resize: vertical;
      }
      .row {
        align-items: center;
        display: flex;
        gap: var(--ark-space-2);
      }
      .row label {
        margin: 0;
      }
      button {
        background: var(--ark-color-accent);
        border: none;
        border-radius: var(--ark-radius-sm, 6px);
        color: var(--ark-color-on-accent, #fff);
        cursor: pointer;
        font: inherit;
        font-weight: var(--ark-weight-semibold);
        padding: var(--ark-space-2) var(--ark-space-4);
      }
      button.ghost {
        background: transparent;
        border: 1px solid var(--ark-color-border);
        color: var(--ark-color-text);
      }
      button.danger {
        background: var(--ark-color-danger);
      }
      #status {
        border-radius: var(--ark-radius-sm, 6px);
        font-size: var(--ark-text-sm);
        margin-top: var(--ark-space-4);
        padding: var(--ark-space-3);
      }
      #status.ok {
        background: color-mix(in srgb, var(--ark-color-secondary) 16%, transparent);
      }
      #status.err {
        background: color-mix(in srgb, var(--ark-color-danger) 16%, transparent);
      }
      ul {
        list-style: none;
        margin: 0;
        padding: 0;
      }
      li {
        align-items: center;
        border-bottom: 1px solid var(--ark-color-border);
        display: flex;
        gap: var(--ark-space-3);
        justify-content: space-between;
        padding: var(--ark-space-2) 0;
      }
      li code {
        font-family: var(--ark-font-mono, monospace);
        font-size: var(--ark-text-sm);
      }
      li .count {
        color: var(--ark-color-text-muted);
        font-size: var(--ark-text-xs, 0.75rem);
        margin-left: auto;
      }
      .disabled-note {
        background: color-mix(in srgb, var(--ark-color-danger) 12%, transparent);
        border-radius: var(--ark-radius-md);
        padding: var(--ark-space-4);
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Knowledge admin</h1>
      <p class="lede">
        Add documents to the Arkhe RAG store. Content is chunked, embedded, and
        saved to Supabase pgvector.
      </p>

      {
        !ragConfigured && (
          <div class="disabled-note">
            Supabase is not configured. Set <code>SUPABASE_URL</code>,
            <code>SUPABASE_SERVICE_ROLE_KEY</code>, and
            <code>OPENAI_API_KEY</code> to enable ingestion.
          </div>
        )
      }

      {
        ragConfigured && (
          <>
            <form id="ingest-form">
              <fieldset>
                <legend>Add a document</legend>
                <div class="field">
                  <label for="source">Source id</label>
                  <input
                    id="source"
                    type="text"
                    placeholder="note:about-hobbies"
                    autocomplete="off"
                  />
                </div>
                <div class="field">
                  <label for="content">Content</label>
                  <textarea
                    id="content"
                    placeholder="Paste markdown or plain text…"
                    required
                  />
                </div>
                <div class="field">
                  <label for="metadata">Metadata (JSON, optional)</label>
                  <textarea id="metadata" placeholder='{"type":"note"}' />
                </div>
                <div class="field row">
                  <input id="replace" type="checkbox" checked />
                  <label for="replace">
                    Replace existing chunks for this source
                  </label>
                </div>
                <button type="submit">Ingest</button>
              </fieldset>
            </form>

            <fieldset>
              <legend>Loaded sources</legend>
              <ul id="sources">
                <li>Loading…</li>
              </ul>
              <div style="margin-top: var(--ark-space-4)">
                <button type="button" class="danger" id="clear-all">
                  Clear everything
                </button>
              </div>
            </fieldset>

            <div id="status" hidden />
          </>
        )
      }
    </main>

    <script>
      interface SourceCount {
        source: string | null;
        chunks: number;
      }
      interface ApiResult {
        ok?: boolean;
        error?: string;
        documents?: number;
        chunks?: number;
        removed?: number;
        sources?: SourceCount[];
      }

      const $ = <T extends HTMLElement>(id: string): T =>
        document.getElementById(id) as T;

      const form = document.getElementById("ingest-form");
      // The form only renders when RAG is configured.
      if (form) {
        const statusEl = $<HTMLDivElement>("status");
        const sourcesEl = $<HTMLUListElement>("sources");

        const setStatus = (message: string, ok: boolean) => {
          statusEl.hidden = false;
          statusEl.textContent = message;
          statusEl.className = ok ? "ok" : "err";
        };

        const api = async (
          method: string,
          body?: unknown,
        ): Promise<ApiResult> => {
          const res = await fetch("/api/admin/ingest", {
            method,
            headers: body ? { "content-type": "application/json" } : {},
            body: body ? JSON.stringify(body) : undefined,
          });
          return (await res.json()) as ApiResult;
        };

        const loadSources = async () => {
          try {
            const data = await api("GET");
            const sources = data.sources ?? [];
            sourcesEl.innerHTML = "";
            if (sources.length === 0) {
              sourcesEl.innerHTML = "<li>No documents yet.</li>";
              return;
            }
            for (const item of sources) {
              const li = document.createElement("li");
              const code = document.createElement("code");
              code.textContent = item.source ?? "(no source)";
              const count = document.createElement("span");
              count.className = "count";
              count.textContent = `${item.chunks} chunks`;
              li.append(code, count);
              if (item.source) {
                const btn = document.createElement("button");
                btn.type = "button";
                btn.className = "ghost";
                btn.textContent = "Clear";
                const sourceId = item.source;
                btn.addEventListener("click", () => {
                  void removeSource(sourceId);
                });
                li.append(btn);
              }
              sourcesEl.append(li);
            }
          } catch {
            sourcesEl.innerHTML = "<li>Failed to load sources.</li>";
          }
        };

        const removeSource = async (source: string) => {
          const data = await api("DELETE", { source });
          setStatus(`Removed ${data.removed ?? 0} chunks from ${source}.`, true);
          await loadSources();
        };

        form.addEventListener("submit", (event) => {
          event.preventDefault();
          void (async () => {
            const content = $<HTMLTextAreaElement>("content").value.trim();
            const source = $<HTMLInputElement>("source").value.trim();
            const replaceSource = $<HTMLInputElement>("replace").checked;
            const metaRaw = $<HTMLTextAreaElement>("metadata").value.trim();

            let metadata: unknown;
            if (metaRaw) {
              try {
                metadata = JSON.parse(metaRaw);
              } catch {
                setStatus("Metadata is not valid JSON.", false);
                return;
              }
            }

            setStatus("Embedding and saving…", true);
            try {
              const data = await api("POST", {
                content,
                source: source || undefined,
                metadata,
                replaceSource,
              });
              if (data.error) {
                setStatus(data.error, false);
                return;
              }
              setStatus(
                `Ingested ${data.documents ?? 0} document → ${data.chunks ?? 0} chunks.`,
                true,
              );
              $<HTMLTextAreaElement>("content").value = "";
              await loadSources();
            } catch {
              setStatus("Request failed.", false);
            }
          })();
        });

        $<HTMLButtonElement>("clear-all").addEventListener("click", () => {
          if (!confirm("Delete ALL knowledge documents?")) return;
          void (async () => {
            const data = await api("DELETE", { all: true });
            setStatus(`Cleared ${data.removed ?? 0} chunks.`, true);
            await loadSources();
          })();
        });

        void loadSources();
      }
    </script>
  </body>
</html>
