---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categoryLabel } from "../../data/expertise";
import CaseStudyVisual from "../../components/CaseStudyVisual.astro";
// Share the case study page's visual language so the project detail feels
// like the same family of pages.
import "../case-studies/_case-study.css";
import "./_projects.css";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const caseStudyIds = new Set(
    (await getCollection("caseStudies")).map((study) => study.id),
  );
  return projects.map((project) => ({
    params: { slug: project.id },
    props: {
      project,
      // A case study shares the project's slug when one exists for it.
      relatedCaseStudyId: caseStudyIds.has(project.id) ? project.id : null,
    },
  }));
}

const { project, relatedCaseStudyId } = Astro.props;
const { title, body, role, challenges, stack, category, screenshots } =
  project.data;
const githubUrl = project.data["github-url"];

// Body is plain prose with blank-line-separated paragraphs.
const paragraphs = body.split("\n\n").map((p) => p.trim()).filter(Boolean);
---

<BaseLayout title={`${title} | Arkaes`} description={challenges}>
  <article class="cs-page">
    <span class="cs-hero-sentinel" aria-hidden="true"></span>
    <header class="cs-hero">
      <div class="cs-hero-visual">
        <CaseStudyVisual visual={project.id} transitionName={`proj-thumb-${project.id}`} />
      </div>

      <div class="cs-hero-meta">
        <div class="cs-hero-eyebrow">{categoryLabel(category)}</div>
        <div class="cs-hero-tags">
          {stack.map((tech) => <ark-badge variant="pill">{tech}</ark-badge>)}
        </div>
        <h1 class="cs-hero-title">{title}</h1>
      </div>
    </header>

    <section class="cs-overview-section">
      <div class="cs-overview-inner">
        <div class="proj-overview-meta">
          <div class="cs-overview-label">Role</div>
          <p class="proj-overview-role">{role}</p>
        </div>
        <div class="cs-overview-body">
          <p>{challenges}</p>
        </div>
      </div>
    </section>

    <section class="cs-accordion-section">
      <div class="cs-accordion-inner proj-body">
        {paragraphs.map((paragraph) => <p>{paragraph}</p>)}

        {
          screenshots.length > 0 && (
            <div class="proj-gallery" role="group" aria-label="Screenshots">
              {screenshots.map((src) => (
                <img src={src} alt={`${title} screenshot`} loading="lazy" />
              ))}
            </div>
          )
        }

        <div class="project-footer-nav">
          {
            githubUrl && (
              <ark-button href={githubUrl} target="_blank" variant="ghost">
                View on GitHub &nearr;
              </ark-button>
            )
          }
          {
            relatedCaseStudyId && (
              <ark-button href={`/case-studies/${relatedCaseStudyId}`} variant="ghost">
                View related case study &nearr;
              </ark-button>
            )
          }
          <ark-button href="/projects" variant="ghost">View all projects &swarr;</ark-button>
        </div>
      </div>
    </section>

    <div class="cs-back">
      <a href="/projects" class="cs-back-link">&larr; Back to projects</a>
    </div>
  </article>
</BaseLayout>

<script>
  // Mirror the case study hero: pin it to the top and collapse its padding
  // once a sentinel above it scrolls out of view. See _case-study.css.
  function initHeroStick() {
    const hero = document.querySelector<HTMLElement>(".cs-hero");
    const sentinel = document.querySelector<HTMLElement>(".cs-hero-sentinel");
    if (!hero || !sentinel) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        hero.classList.toggle("is-stuck", !entry.isIntersecting);
      },
      { threshold: 0 },
    );
    observer.observe(sentinel);

    document.addEventListener(
      "astro:before-swap",
      () => observer.disconnect(),
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initHeroStick);
</script>
