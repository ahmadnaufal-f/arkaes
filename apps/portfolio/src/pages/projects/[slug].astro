---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categoryLabel } from "../../data/expertise";
import "./_projects.css";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const caseStudyIds = new Set(
    (await getCollection("caseStudies")).map((study) => study.id),
  );
  return projects.map((project) => ({
    params: { slug: project.id },
    props: {
      project,
      // A case study shares the project's slug when one exists for it.
      relatedCaseStudyId: caseStudyIds.has(project.id) ? project.id : null,
    },
  }));
}

const { project, relatedCaseStudyId } = Astro.props;
const { title, body, role, challenges, stack, category, screenshots } =
  project.data;
const githubUrl = project.data["github-url"];

// Body is plain prose with blank-line-separated paragraphs.
const paragraphs = body.split("\n\n").map((p) => p.trim()).filter(Boolean);
---

<BaseLayout title={`${title} | Arkaes`} description={challenges}>
  <article class="page-section narrow project-detail">
    <ark-badge>{categoryLabel(category)}</ark-badge>
    <h1>{title}</h1>

    <dl class="project-meta">
      <div>
        <dt>Role</dt>
        <dd>{role}</dd>
      </div>
      <div>
        <dt>Challenges</dt>
        <dd>{challenges}</dd>
      </div>
      <div>
        <dt>Stack</dt>
        <dd>{stack.join(", ")}</dd>
      </div>
    </dl>

    <section>
      {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </section>

    {
      screenshots.length > 0 && (
        <section class="project-gallery" aria-label="Screenshots">
          {screenshots.map((src) => (
            <img src={src} alt={`${title} screenshot`} loading="lazy" />
          ))}
        </section>
      )
    }

    <div class="project-footer-nav">
      {
        githubUrl && (
          <ark-button href={githubUrl} target="_blank" variant="ghost">
            View on GitHub &nearr;
          </ark-button>
        )
      }
      {
        relatedCaseStudyId && (
          <ark-button href={`/case-studies/${relatedCaseStudyId}`} variant="ghost">
            View related case study &nearr;
          </ark-button>
        )
      }
      <ark-button href="/projects" variant="ghost">View all projects &swarr;</ark-button>
    </div>
  </article>
</BaseLayout>
