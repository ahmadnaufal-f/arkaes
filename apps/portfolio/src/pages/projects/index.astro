---
import { professionalProjects, sideProjects } from "../../data/projects";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Projects | Arkaes"
  description="Professional work and side projects from the Arkaes portfolio."
>
  <section class="page-section">
    <div class="section-heading">
      <ark-badge>Projects</ark-badge>
      <h1>Professional work and side projects, separated by context.</h1>
    </div>

    <div class="project-listing">
      <section aria-labelledby="professional-work">
        <h2 id="professional-work">Professional Works</h2>
        <div class="project-grid">
          {
            professionalProjects.map((project) => (
              <ark-card>
                <a class="project-card" href={`/projects/${project.slug}`}>
                  <span>Professional Work</span>
                  <h3>{project.title}</h3>
                  <p>{project.summary}</p>
                </a>
              </ark-card>
            ))
          }
        </div>
      </section>

      <section aria-labelledby="side-projects">
        <h2 id="side-projects">Side Projects</h2>
        <div class="project-grid">
          {
            sideProjects.map((project) => (
              <ark-card>
                <a class="project-card" href={`/projects/${project.slug}`}>
                  <span>Side Project</span>
                  <h3>{project.title}</h3>
                  <p>{project.summary}</p>
                </a>
              </ark-card>
            ))
          }
        </div>
      </section>
    </div>
  </section>

  <script>
    import "@arkaes/ui";
  </script>
</BaseLayout>

