---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilterableListing from "../../components/FilterableListing.astro";
import type { ListingItem } from "../../components/FilterableListing.astro";
import { expertiseForProject } from "../../data/expertise";

// Order by shipped date, most recent first.
const entries = (await getCollection("projects")).sort(
  (a, b) => b.data.shippedDate.getTime() - a.data.shippedDate.getTime(),
);
const items: ListingItem[] = entries.map((project) => ({
  title: project.data.title,
  // Body teaser; the card clamps it to three lines with an ellipsis.
  summary: project.data.body,
  href: `/projects/${project.id}`,
  categorySlug: project.data.category,
  expertise: expertiseForProject(project.data.projectName),
  tags: project.data.stack.slice(0, 3),
  // Slug doubles as the visual registry key (falls back to the brand mark).
  visual: project.id,
  transitionName: `proj-thumb-${project.id}`,
}));
---

<BaseLayout
  title="Projects | Arkaes"
  description="Professional work and side projects from the Arkaes portfolio."
>
  <FilterableListing
    eyebrow="Projects"
    title="Selected work, by context and expertise."
    description="Professional engagements and side projects, filterable in one place."
    items={items}
  />
</BaseLayout>
