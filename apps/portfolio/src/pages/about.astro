---
import BaseLayout from "../layouts/BaseLayout.astro";
import "./_about.css";
---

<BaseLayout
  title="About | Arkaes"
  description="About Arkaes, a frontend engineer portfolio focused on architecture, interaction, performance, and visual craft."
>
  <section class="page-section narrow">
    <ark-badge>About</ark-badge>
    <h1>Frontend engineering with a product eye.</h1>
    <p class="lead">
      Arkaes is a portfolio direction for work that sits between implementation detail and user
      experience: practical systems, thoughtful interfaces, and case studies that explain the work
      without inflating it.
    </p>
  </section>

  <script>
    import "@arkaes/ui/register/ark-badge";
  </script>
</BaseLayout>
