---
import BaseLayout from "../layouts/BaseLayout.astro";
import { parseSections, renderSectionHtml } from "../utils/sections";
import aboutContent from "../content/about.md?raw";
import "./_about.css";

// Eagerly import every about illustration SVG as a raw string so we can
// inline it and let the page's loaded Google Fonts apply inside the markup.
const svgModules = import.meta.glob<string>("../../public/about/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});

const diagrams: Record<string, string> = {};
for (const [path, source] of Object.entries(svgModules)) {
  const fileName = path.split("/").pop()?.replace(".svg", "");
  if (fileName) diagrams[fileName] = source;
}

// Sections live in src/content/about.md, one `## Heading` per accordion item.
const sections = parseSections(aboutContent);
---

<BaseLayout
  title="About | Arkaes"
  description="About Ahmad Naufal, a frontend engineer focused on scalable, maintainable, and pleasant interfaces."
>
  <section class="page-section narrow">
    <ark-page-header
      eyebrow="About"
      heading="Frontend engineering with a product eye."
    ></ark-page-header>

    <ark-accordion class="about-accordion">
      {
        sections.map(({ heading, content }, index) => (
          <ark-accordion-item heading={heading} open={index === 0 ? "" : undefined}>
            {index === 0 && (
              <img
                class="about-summary-portrait"
                src="/about-me.png"
                alt="Ahmad Naufal"
                width="320"
                height="427"
                transition:name="about-me"
              />
            )}
            <div
              class="about-body"
              set:html={renderSectionHtml(content, diagrams)}
            />
          </ark-accordion-item>
        ))
      }
    </ark-accordion>

    <div class="about-footer-nav">
      <ark-button href="/" variant="ghost">&larr; Back to home page</ark-button>
    </div>
  </section>
</BaseLayout>
