---
import BaseLayout from "../layouts/BaseLayout.astro";
import "./_index.css";
import { techGroups, currentlyLearning } from "../data/techstack";
---

<BaseLayout
  title="Arkaes - Performance-focused Frontend Engineering Portfolio"
  description="Performance-focused frontend engineering portfolio for UI systems, design systems, and cross-platform products."
>
  <a class="skip-link" href="#case-studies">Skip to case studies</a>
  <div class="cursor" id="cursor" aria-hidden="true"></div>
  <div class="cursor-ring" id="cursorRing" aria-hidden="true"></div>

  <ark-hero
    eyebrow="Frontend Engineer &amp; UI Systems Architect"
    title="Frontend engineering"
    title-emphasis="with clarity."
    subtitle="Building scalable interfaces, design systems, and cross-platform products where technical structure and visual refinement work as one."
    primary-href="#case-studies"
    primary-label="View Case Studies"
    ghost-href="#expertise"
    ghost-label="Explore engineering approach"
    comp-label="Ahmad Naufal - mmxxvi"
    scroll-label="Explore the work"
  ></ark-hero>

  <div class="marquee-section" aria-hidden="true">
    <div class="marquee-track">
      <div class="marquee-item">Frontend Architecture</div>
      <div class="marquee-item">Design Systems</div>
      <div class="marquee-item">Performance Engineering</div>
      <div class="marquee-item">Cross-platform Apps</div>
      <div class="marquee-item">Interaction Engineering</div>
      <div class="marquee-item">Product Thinking</div>
      <div class="marquee-item">Frontend Architecture</div>
      <div class="marquee-item">Design Systems</div>
      <div class="marquee-item">Performance Engineering</div>
      <div class="marquee-item">Cross-platform Apps</div>
      <div class="marquee-item">Interaction Engineering</div>
      <div class="marquee-item">Product Thinking</div>
    </div>
  </div>

  <section class="work-section" id="case-studies">
    <div class="section-header reveal">
      <div>
        <div class="section-eyebrow">Selected Case Studies</div>
        <h2 class="section-title">Systems I have <em>shaped</em></h2>
      </div>
      <div class="section-count">04 / Selected</div>
    </div>

    <div class="projects-grid reveal reveal-delay-1">
      <ark-case-study-card
        class="project-card"
        href="/projects/smartthings-air-care-service"
        title="Samsung Plugin Optimization"
      >
        <div class="thumb-1" slot="media">
          <div class="thumb-1-inner">
            <div class="thumb-1-text">&AElig;</div>
          </div>
        </div>
        <ark-badge slot="tag" variant="pill">Performance</ark-badge>
        <ark-badge slot="tag" variant="pill">UI Architecture</ark-badge>
        <ark-badge slot="tag" variant="pill">Samsung</ark-badge>
      </ark-case-study-card>

      <ark-case-study-card
        class="project-card"
        href="/projects/treely"
        title="Treely Family Tree App"
      >
        <div class="thumb-2" slot="media">
          <div class="thumb-2-grid">
            <div class="thumb-2-cell"></div>
            <div class="thumb-2-cell"></div>
            <div class="thumb-2-cell"></div>
            <div class="thumb-2-cell"></div>
            <div class="thumb-2-cell"></div>
            <div class="thumb-2-cell"></div>
            <div class="thumb-2-cell"></div>
            <div class="thumb-2-cell"></div>
          </div>
        </div>
        <ark-badge slot="tag" variant="pill">React Native</ark-badge>
        <ark-badge slot="tag" variant="pill">Product Lead</ark-badge>
      </ark-case-study-card>

      <ark-case-study-card
        class="project-card"
        href="/projects/milk-tracker-app"
        title="Milk Pumping Insights"
      >
        <div class="thumb-3" slot="media">
          <div class="thumb-3-ring">
            <div class="thumb-3-fill"></div>
          </div>
        </div>
        <ark-badge slot="tag" variant="pill">AI Feature</ark-badge>
        <ark-badge slot="tag" variant="pill">Product UX</ark-badge>
      </ark-case-study-card>
    </div>
  </section>

  <section class="services-section" id="expertise">
    <div class="section-header reveal">
      <div>
        <div class="section-eyebrow">Core Expertise</div>
        <h2 class="section-title">Engineering <em>focus</em></h2>
      </div>
    </div>

    <div class="services-list">
      <a class="service-item reveal" href="/projects">
        <span class="service-num">01</span>
        <span class="service-name">Frontend Architecture &amp; UI Systems</span>
        <span class="service-arrow">&rarr;</span>
      </a>
      <a class="service-item reveal reveal-delay-1" href="/projects">
        <span class="service-num">02</span>
        <span class="service-name">Design Systems Engineering</span>
        <span class="service-arrow">&rarr;</span>
      </a>
      <a class="service-item reveal reveal-delay-2" href="/projects">
        <span class="service-num">03</span>
        <span class="service-name">Performance-focused Frontend Engineering</span>
        <span class="service-arrow">&rarr;</span>
      </a>
      <a class="service-item reveal reveal-delay-3" href="/projects">
        <span class="service-num">04</span>
        <span class="service-name">Cross-platform Product Development</span>
        <span class="service-arrow">&rarr;</span>
      </a>
    </div>
  </section>

  <section class="techstack-section" id="techstack">
    <div class="section-header reveal">
      <div>
        <div class="section-eyebrow">Tech Stacks &amp; Tools</div>
        <h2 class="section-title">What I <em>build with</em></h2>
      </div>
      <div class="techstack-meta">
        7 Domains<br />
        33+ Technologies
      </div>
    </div>

    <div class="techstack-grid">
      {techGroups.map((group, index) => {
        const num = String(index + 1).padStart(2, "0");
        const delay = `reveal-delay-${index + 1}`;
        const extraClasses = [group.emerging && "techstack-card--emerging", group.wide && "techstack-card--wide"].filter(Boolean).join(" ");
        const classStr = extraClasses ? `techstack-card ${extraClasses}` : "techstack-card";
        return (
          <article class={`${classStr} reveal ${delay}`}>
            <div class="techstack-number">{num}</div>
            <h3 class="techstack-label">{group.label}</h3>
            <div class="techstack-rule"></div>
            <div class="techstack-pills">
              {group.items.map((item) => (
                <span class={`techstack-pill${item.primary ? " techstack-pill--primary" : ""}`}>
                  {item.name}
                </span>
              ))}
            </div>
          </article>
        );
      })}
    </div>

    <div class="techstack-footer reveal">
      <p class="techstack-note">
        Primary framework is Lit for enterprise work. React for side projects and experiments. All
        stacks applied to shipped, production software.
      </p>
      <div class="techstack-learning">
        <div class="techstack-learning-label">Currently learning</div>
        <div class="techstack-learning-pills">
          {currentlyLearning.map((item) => (
            <span class="techstack-learning-pill">{item}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="about-strip" id="about">
    <div class="about-portrait reveal">
      <div class="portrait-placeholder">
        <div class="portrait-monogram">A</div>
      </div>
      <div class="portrait-rule"></div>
    </div>
    <div class="about-content reveal reveal-delay-2">
      <div class="section-eyebrow">About</div>
      <h2 class="about-title">Engineering <em>structure</em><br />for product clarity</h2>
      <p class="about-body">
        A frontend engineer focused on the intersection of system quality and interface craft. I
        build product experiences with clear architecture, thoughtful interaction, and enough visual
        sensitivity to make complexity feel calm.
      </p>
      <div class="about-stats">
        <div>
          <div class="stat-number">6<span>+</span></div>
          <div class="stat-label">Years building</div>
        </div>
        <div>
          <div class="stat-number">40<span>+</span></div>
          <div class="stat-label">Projects shipped</div>
        </div>
        <div>
          <div class="stat-number">3</div>
          <div class="stat-label">Core stacks</div>
        </div>
      </div>
    </div>
  </section>

  <section class="contact-section" id="contact">
    <div class="contact-inner reveal">
      <ark-badge variant="eyebrow">Get in touch</ark-badge>
      <h2 class="contact-title">Let's build interfaces<br /><em>that hold up.</em></h2>
      <a href="mailto:ahmadnaufal611@gmail.com" class="contact-email">
        ahmadnaufal611@gmail.com
      </a>
      <div class="contact-socials">
        <a href="#" class="contact-social-link">GitHub</a>
        <a href="#" class="contact-social-link">LinkedIn</a>
        <a href="#case-studies" class="contact-social-link">Case Studies</a>
      </div>
    </div>
  </section>

  <script>
    import "@arkaes/ui/register/ark-badge";
    import "@arkaes/ui/register/ark-case-study-card";
    import "@arkaes/ui/register/ark-hero";

    const cursor = document.getElementById("cursor");
    const ring = document.getElementById("cursorRing");
    const canUseCursor = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

    if (cursor && ring && canUseCursor) {
      let mouseX = 0;
      let mouseY = 0;
      let ringX = 0;
      let ringY = 0;

      document.body.classList.add("has-custom-cursor");

      document.addEventListener("mousemove", (event) => {
        mouseX = event.clientX;
        mouseY = event.clientY;
        cursor.style.left = `${mouseX}px`;
        cursor.style.top = `${mouseY}px`;
      });

      const animateRing = () => {
        ringX += (mouseX - ringX) * 0.12;
        ringY += (mouseY - ringY) * 0.12;
        ring.style.left = `${ringX}px`;
        ring.style.top = `${ringY}px`;
        requestAnimationFrame(animateRing);
      };

      animateRing();

      document.querySelectorAll("a, button, ark-card, ark-case-study-card").forEach((element) => {
        element.addEventListener("mouseenter", () => document.body.classList.add("hovering"));
        element.addEventListener("mouseleave", () => document.body.classList.remove("hovering"));
      });
    }

    const reveals = document.querySelectorAll(".reveal");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
          }
        });
      },
      { threshold: 0.1 },
    );

    reveals.forEach((element) => {
      const completeReveal = (event: Event) => {
        if (
          event instanceof TransitionEvent &&
          event.propertyName === "opacity" &&
          element.classList.contains("visible")
        ) {
          element.classList.add("reveal-complete");
          element.removeEventListener("transitionend", completeReveal);
        }
      };

      element.addEventListener("transitionend", completeReveal);
      observer.observe(element);
    });


  </script>
</BaseLayout>
