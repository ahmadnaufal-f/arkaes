---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import "./_index.css";
import { techGroups, currentlyLearning } from "../data/techstack";
import { EXPERTISE } from "../data/expertise";
import CaseStudyVisual from "../components/CaseStudyVisual.astro";

const CARD_ORDER = ["virtual-home", "virtual-home-tv", "milk-tracker", "air-care"];
const getOrder = (id: string) => { const i = CARD_ORDER.indexOf(id); return i === -1 ? Infinity : i; };

const allStudies = await getCollection("caseStudies");
const featuredStudies = allStudies
  .filter((s) => s.data.featured)
  .sort((a, b) => getOrder(a.id) - getOrder(b.id));

const services = EXPERTISE.map((area) => ({
  name: area.label,
  description: area.description,
  techStack: area.techStack,
  relatedWork: area.relatedWork,
}));
---

<BaseLayout
  title="Arkaes - Performance-focused Frontend Engineering Portfolio"
  description="Performance-focused frontend engineering portfolio for UI systems, design systems, and cross-platform products."
>
  <a class="skip-link" href="#case-studies">Skip to case studies</a>

  <ark-hero
    eyebrow="Frontend Engineer &amp; UI Systems Architect"
    title="Frontend engineering"
    title-emphasis="with clarity."
    subtitle="Building scalable interfaces, design systems, and cross-platform products where technical structure and visual refinement work as one."
    primary-href="#case-studies"
    primary-label="View Case Studies"
    ghost-href="#expertise"
    ghost-label="Explore engineering approach"
    comp-label="Ahmad Naufal - mmxxvi"
    scroll-label="Explore the work"
  ></ark-hero>

  <div class="marquee-section" aria-hidden="true">
    <div class="marquee-track" data-marquee-track>
      <div class="marquee-group" data-marquee-group>
        <div class="marquee-item">Frontend Architecture</div>
        <div class="marquee-item">Design Systems</div>
        <div class="marquee-item">Performance Engineering</div>
        <div class="marquee-item">Cross-platform Apps</div>
        <div class="marquee-item">Interaction Engineering</div>
        <div class="marquee-item">Product Thinking</div>
      </div>
    </div>
  </div>

  <script>
    const SECONDS_PER_GROUP = 24;

    function setupMarquee(track: HTMLElement) {
      const base = track.querySelector<HTMLElement>("[data-marquee-group]");
      if (!base) return;

      track
        .querySelectorAll("[data-marquee-group][data-clone]")
        .forEach((node) => node.remove());

      const groupWidth = base.offsetWidth;
      if (groupWidth === 0) return;

      const copiesPerHalf = Math.max(1, Math.ceil(window.innerWidth / groupWidth));
      const totalGroups = copiesPerHalf * 2;

      const fragment = document.createDocumentFragment();
      for (let i = 1; i < totalGroups; i += 1) {
        const clone = base.cloneNode(true) as HTMLElement;
        clone.setAttribute("data-clone", "");
        fragment.appendChild(clone);
      }
      track.appendChild(fragment);
      track.style.animationDuration = `${copiesPerHalf * SECONDS_PER_GROUP}s`;
    }

    function initMarquees() {
      document
        .querySelectorAll<HTMLElement>("[data-marquee-track]")
        .forEach(setupMarquee);
    }

    let resizeTimer: number | undefined;
    window.addEventListener("resize", () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(initMarquees, 150);
    });

    initMarquees();
  </script>

  <section class="work-section" id="case-studies">
    <div class="section-header reveal">
      <div>
        <div class="section-eyebrow">Selected Case Studies</div>
        <h2 class="section-title">Systems I have <em>shaped</em></h2>
      </div>
      <div class="section-count">{String(featuredStudies.length).padStart(2, "0")} / Selected</div>
    </div>

    <div class="projects-carousel">
    <div class="projects-grid reveal reveal-delay-1">
      {featuredStudies.map((study) => (
        <ark-case-study-card
          class="project-card"
          href={`/case-studies/${study.id}`}
          title={study.data.title}
        >
          <CaseStudyVisual
            visual={study.data.visual}
            asSlot="media"
            transitionName={`proj-thumb-${study.id}`}
          />
          {study.data.tags.map((tag) => (
            <ark-chip slot="tag">{tag}</ark-chip>
          ))}
        </ark-case-study-card>
      ))}
    </div>

    <div class="projects-nav" aria-label="Case study navigation">
      <button class="projects-nav-btn" data-carousel-prev aria-label="Previous case study" disabled>&#8592;</button>
      <span class="projects-nav-indicator" aria-live="polite">
        <span data-carousel-current>01</span> / {String(featuredStudies.length).padStart(2, "0")}
      </span>
      <button class="projects-nav-btn" data-carousel-next aria-label="Next case study">&#8594;</button>
    </div>
    </div>

    <div class="section-cta reveal">
      <ark-button href="/case-studies" variant="secondary">View all case studies</ark-button>
      <ark-button href="/projects" variant="ghost">Browse all projects</ark-button>
    </div>
  </section>

  <script>
    (function () {
      const grid = document.querySelector<HTMLElement>(".projects-grid");
      const prevBtn = document.querySelector<HTMLButtonElement>("[data-carousel-prev]");
      const nextBtn = document.querySelector<HTMLButtonElement>("[data-carousel-next]");
      const currentEl = document.querySelector<HTMLElement>("[data-carousel-current]");
      if (!grid || !prevBtn || !nextBtn || !currentEl) return;

      const cards = Array.from(grid.querySelectorAll<HTMLElement>(".project-card"));
      const total = cards.length;
      let current = 0;

      function isActive() {
        return window.getComputedStyle(prevBtn!).display !== "none";
      }

      function updateNav() {
        currentEl!.textContent = String(current + 1).padStart(2, "0");
        prevBtn!.disabled = current === 0;
        nextBtn!.disabled = current === total - 1;
      }

      function goTo(index: number) {
        current = Math.max(0, Math.min(total - 1, index));
        cards[current].scrollIntoView({ behavior: "smooth", block: "nearest", inline: "start" });
        updateNav();
      }

      let scrollTimer: ReturnType<typeof setTimeout>;
      grid.addEventListener("scroll", () => {
        if (!isActive()) return;
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => {
          const gridLeft = grid.getBoundingClientRect().left;
          let closest = 0;
          let closestDist = Infinity;
          cards.forEach((card, i) => {
            const dist = Math.abs(card.getBoundingClientRect().left - gridLeft);
            if (dist < closestDist) { closestDist = dist; closest = i; }
          });
          if (closest !== current) { current = closest; updateNav(); }
        }, 80);
      }, { passive: true });

      prevBtn.addEventListener("click", () => { if (isActive()) goTo(current - 1); });
      nextBtn.addEventListener("click", () => { if (isActive()) goTo(current + 1); });

      updateNav();
    })();
  </script>

  <section class="services-section" id="expertise">
    <div class="section-header reveal">
      <div>
        <div class="section-eyebrow">Core Expertise</div>
        <h2 class="section-title">Engineering <em>focus</em></h2>
      </div>
    </div>

    <ark-accordion class="services-list" type="single">
      {services.map((service, index) => (
        <ark-accordion-item class={`service-item reveal${index > 0 ? ` reveal-delay-${index}` : ""}`}>
          <span slot="trigger" class="service-trigger">
            <span class="service-num">{String(index + 1).padStart(2, "0")}</span>
            <span class="service-name">{service.name}</span>
          </span>
          <div class="service-body">
            <p class="service-desc">{service.description}</p>
            <div class="service-meta">
              <div class="service-meta-group">
                <div class="service-meta-label">Tech stack</div>
                <div class="service-tags">
                  {service.techStack.map((tech) => (
                    <ark-chip>{tech}</ark-chip>
                  ))}
                </div>
              </div>
              <div class="service-meta-group">
                <div class="service-meta-label">Related work</div>
                <div class="service-tags">
                  {service.relatedWork.map((work) => (
                    <ark-chip variant="accent">{work}</ark-chip>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </ark-accordion-item>
      ))}
    </ark-accordion>
  </section>

  <section class="techstack-section" id="techstack">
    <div class="section-header reveal">
      <div>
        <div class="section-eyebrow">Tech Stacks &amp; Tools</div>
        <h2 class="section-title">What I <em>build with</em></h2>
      </div>
      <div class="techstack-meta">
        7 Domains<br />
        33+ Technologies
      </div>
    </div>

    <div class="techstack-grid">
      {techGroups.map((group, index) => {
        const num = String(index + 1).padStart(2, "0");
        const delay = `reveal-delay-${index + 1}`;
        const extraClasses = [group.emerging && "techstack-card--emerging", group.wide && "techstack-card--wide"].filter(Boolean).join(" ");
        const classStr = extraClasses ? `techstack-card ${extraClasses}` : "techstack-card";
        return (
          <article class={`${classStr} reveal ${delay}`}>
            <div class="techstack-number">{num}</div>
            <h3 class="techstack-label">{group.label}</h3>
            <div class="techstack-rule"></div>
            <div class="techstack-pills">
              {group.items.map((item) => (
                <ark-chip variant={group.emerging ? (item.primary ? "emerging" : "default") : (item.primary ? "primary" : "default")}>
                  {item.name}
                </ark-chip>
              ))}
            </div>
          </article>
        );
      })}
    </div>

    <div class="techstack-footer reveal">
      <p class="techstack-note">
        Primary framework is Lit for enterprise work. React for side projects and experiments. All
        stacks applied to shipped, production software.
      </p>
      <div class="techstack-learning">
        <div class="techstack-learning-label">Currently learning</div>
        <div class="techstack-learning-pills">
          {currentlyLearning.map((item) => (
            <ark-chip variant="learning">{item}</ark-chip>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    // Light up every chip in a tech-stack card when the card is hovered.
    // ark-chip lives in shadow DOM, so this drives its isHovered API rather
    // than relying on a CSS descendant selector.
    (function () {
      const cards = document.querySelectorAll<HTMLElement>(".techstack-card");
      cards.forEach((card) => {
        const chips = card.querySelectorAll<HTMLElement & { isHovered: boolean }>("ark-chip");
        const setHovered = (value: boolean) => {
          chips.forEach((chip) => {
            chip.isHovered = value;
          });
        };
        card.addEventListener("mouseenter", () => setHovered(true));
        card.addEventListener("mouseleave", () => setHovered(false));
      });
    })();
  </script>

  <section class="about-strip" id="about">
    <div class="about-portrait reveal">
      <div class="portrait-placeholder">
        <div class="portrait-monogram">A</div>
      </div>
      <div class="portrait-rule"></div>
    </div>
    <div class="about-content reveal reveal-delay-2">
      <div class="section-eyebrow">About</div>
      <h2 class="about-title">Engineering <em>structure</em><br />for product clarity</h2>
      <p class="about-body">
        A frontend engineer focused on the intersection of system quality and interface craft. I
        build product experiences with clear architecture, thoughtful interaction, and enough visual
        sensitivity to make complexity feel calm.
      </p>
      <div class="about-stats">
        <div>
          <div class="stat-number">6<span>+</span></div>
          <div class="stat-label">Years building</div>
        </div>
        <div>
          <div class="stat-number">40<span>+</span></div>
          <div class="stat-label">Projects shipped</div>
        </div>
        <div>
          <div class="stat-number">3</div>
          <div class="stat-label">Core stacks</div>
        </div>
      </div>
    </div>
  </section>

  <section class="contact-section" id="contact">
    <div class="contact-inner">
      <ark-badge variant="eyebrow" class="reveal">Get in touch</ark-badge>
      <h2 class="contact-title reveal reveal-delay-1">
        Let's build interfaces<br /><em>that hold up.</em>
      </h2>
      <a
        href="mailto:ahmadnaufal611@gmail.com"
        class="contact-email reveal reveal-delay-2"
      >
        ahmadnaufal611@gmail.com
      </a>
      <div class="contact-socials reveal reveal-delay-3">
        <a href="#" class="contact-social-link">GitHub</a>
        <a href="#" class="contact-social-link">LinkedIn</a>
        <a href="#case-studies" class="contact-social-link">Case Studies</a>
      </div>
    </div>

    <div class="contact-wordmark" aria-hidden="true">
      <span class="wordmark">ARK<em class="ae">&AElig;</em>S</span>
    </div>
  </section>

</BaseLayout>
