---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { parseSections, renderSectionHtml } from "../../utils/case-study";
import "./_case-study.css";
import "@arkaes/ui/components/ark-accordion";
import CaseStudyVisual from "../../components/CaseStudyVisual.astro";

// Eagerly import every case study SVG as a raw string so we can inline it and
// let the page's loaded Google Fonts apply inside the diagram markup.
const svgModules = import.meta.glob<string>(
  "../../../public/case-studies/**/*.svg",
  { query: "?raw", import: "default", eager: true },
);

type CaseStudy = {
  id: string;
  data: {
    title: string;
    shortDesc: string;
    tags: string[];
    visual: string;
  };
  body?: string;
};

export async function getStaticPaths() {
  const studies = (await getCollection("caseStudies")) as CaseStudy[];

  return studies.map((study) => ({
    params: { id: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { title, shortDesc, tags, visual } = study.data;

// Build a map of { fileName (no extension) → SVG source } for this study
const diagrams: Record<string, string> = {};
const prefix = `/case-studies/${study.id}/`;
for (const [path, source] of Object.entries(svgModules)) {
  const idx = path.indexOf(prefix);
  if (idx === -1) continue;
  const fileName = path.slice(idx + prefix.length).replace(".svg", "");
  diagrams[fileName] = source;
}

const allSections = parseSections(study.body ?? "");
const overviewSection = allSections.find((s) => s.heading === "Overview");
const accordionSections = allSections.filter((s) => s.heading !== "Overview");
---

<BaseLayout title={`${title} — Arkaes`} description={shortDesc}>
  <article class="cs-page">
    <span class="cs-hero-sentinel" aria-hidden="true"></span>

    {/* Compact, pinned title bar — only ever shown on mobile touch screens,
        where it cross-fades in as the large hero title scrolls away (One UI
        extendable app-bar pattern). Decorative duplicate of the <h1>. */}
    <div class="cs-titlebar" aria-hidden="true">
      <span class="cs-titlebar-text">{title}</span>
    </div>

    <header class="cs-hero">
      <div class="cs-hero-visual">
        <CaseStudyVisual visual={visual} transitionName={`cs-thumb-${study.id}`} />
      </div>

      <div class="cs-hero-meta">
        <div class="cs-hero-eyebrow">Case Study</div>
        <div class="cs-hero-tags">
          {
            tags.map((tag: string) => (
              <ark-badge variant="pill">{tag}</ark-badge>
            ))
          }
        </div>
        <h1 class="cs-hero-title">{title}</h1>
      </div>
    </header>

    {
      overviewSection && (
        <section class="cs-overview-section">
          <div class="cs-overview-inner">
            <div class="cs-overview-label">Overview</div>
            <div
              class="cs-overview-body"
              set:html={renderSectionHtml(overviewSection.content, diagrams)}
            />
          </div>
        </section>
      )
    }

    <section class="cs-accordion-section">
      <div class="cs-accordion-inner">
        <ark-accordion>
          {
            accordionSections.map((section) => (
              <ark-accordion-item heading={section.heading}>
                <div
                  class="cs-section-content"
                  set:html={renderSectionHtml(section.content, diagrams)}
                />
              </ark-accordion-item>
            ))
          }
        </ark-accordion>
      </div>
    </section>

    <div class="cs-back">
      <a href="/#case-studies" class="cs-back-link"
        >&larr; Back to case studies</a
      >
    </div>
  </article>
</BaseLayout>

<script>
  type Teardown = () => void;

  // ── Desktop / pointer: fine ────────────────────────────────────────────
  // Toggle a `.is-stuck` class on the hero once it pins to the top, so it can
  // collapse its padding. A zero-cost IntersectionObserver watches a sentinel
  // sitting at the hero's top edge instead of listening to every scroll frame.
  function initStuckHero(hero: HTMLElement, sentinel: HTMLElement): Teardown {
    // The spacer sits at the very top of the page and is as tall as the stick
    // offset, so it's fully visible at rest (not stuck) and only scrolls past
    // the viewport top once the hero is pinned (stuck).
    const observer = new IntersectionObserver(
      ([entry]) => {
        hero.classList.toggle("is-stuck", !entry.isIntersecting);
      },
      { threshold: 0 },
    );
    observer.observe(sentinel);
    return () => {
      observer.disconnect();
      hero.classList.remove("is-stuck");
    };
  }

  // ── Mobile + touch: One UI extendable title bar ────────────────────────
  // Replicates Samsung One UI's large app-bar title. The hero scrolls away
  // normally; its progress (0 → 1) is fed to CSS via `--cs-collapse` so the
  // big centered title fades out while the pinned compact bar fades in. At the
  // very top, dragging down stretches the header (rubber band) through
  // `--cs-extend`, which springs back on release.
  function initOneUiHero(hero: HTMLElement): Teardown {
    hero.classList.remove("is-stuck");
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const MAX_EXTEND = 96; // px the header can be pulled open
    // Scroll span over which the big title fully collapses — the hero's own
    // height minus the docked toolbar, so it fades out right as it leaves.
    let distance = Math.max(120, hero.offsetHeight - 60);
    let extend = 0;
    let ticking = false;
    let springTimer = 0;

    const applyCollapse = () => {
      ticking = false;
      const progress = Math.min(1, Math.max(0, window.scrollY / distance));
      hero.style.setProperty("--cs-collapse", progress.toFixed(4));
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(applyCollapse);
      }
    };
    const onResize = () => {
      distance = Math.max(120, hero.offsetHeight - 60);
      applyCollapse();
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize, { passive: true });
    applyCollapse();

    // Rubber-band pull-to-extend while resting at the top of the page.
    let startY = 0;
    let pulling = false;
    const setExtend = (value: number) => {
      extend = value;
      hero.style.setProperty("--cs-extend", value.toFixed(1));
    };
    const springBack = () => {
      if (!reduceMotion) {
        hero.classList.add("cs-hero--springing");
        clearTimeout(springTimer);
        springTimer = window.setTimeout(
          () => hero.classList.remove("cs-hero--springing"),
          520,
        );
      }
      setExtend(0);
    };
    const onTouchStart = (event: TouchEvent) => {
      if (window.scrollY > 0) {
        pulling = false;
        return;
      }
      startY = event.touches[0].clientY;
      pulling = true;
      clearTimeout(springTimer);
      hero.classList.remove("cs-hero--springing");
    };
    const onTouchMove = (event: TouchEvent) => {
      if (!pulling) return;
      const dy = event.touches[0].clientY - startY;
      if (dy <= 0 || window.scrollY > 0) {
        if (extend) springBack();
        pulling = false;
        return;
      }
      // Stop native overscroll so our own stretch shows instead.
      event.preventDefault();
      // Diminishing returns the further you pull.
      setExtend(MAX_EXTEND * (1 - Math.exp(-dy / 220)));
    };
    const onTouchEnd = () => {
      if (pulling && extend > 0) springBack();
      pulling = false;
    };

    if (!reduceMotion) {
      window.addEventListener("touchstart", onTouchStart, { passive: true });
      window.addEventListener("touchmove", onTouchMove, { passive: false });
      window.addEventListener("touchend", onTouchEnd, { passive: true });
      window.addEventListener("touchcancel", onTouchEnd, { passive: true });
    }

    return () => {
      window.removeEventListener("scroll", onScroll);
      window.removeEventListener("resize", onResize);
      window.removeEventListener("touchstart", onTouchStart);
      window.removeEventListener("touchmove", onTouchMove);
      window.removeEventListener("touchend", onTouchEnd);
      window.removeEventListener("touchcancel", onTouchEnd);
      clearTimeout(springTimer);
      hero.classList.remove("cs-hero--springing");
      hero.style.removeProperty("--cs-collapse");
      hero.style.removeProperty("--cs-extend");
    };
  }

  function initHero() {
    const hero = document.querySelector<HTMLElement>(".cs-hero");
    const sentinel = document.querySelector<HTMLElement>(".cs-hero-sentinel");
    if (!hero || !sentinel) return;

    // Only touch-capable phone-sized screens get the One UI treatment.
    const mql = window.matchMedia("(pointer: coarse) and (max-width: 860px)");
    let teardown: Teardown = () => {};
    const setup = () => {
      teardown();
      teardown = mql.matches
        ? initOneUiHero(hero)
        : initStuckHero(hero, sentinel);
    };
    setup();
    mql.addEventListener("change", setup);

    // Tear down before a View Transition swaps the page out.
    document.addEventListener(
      "astro:before-swap",
      () => {
        teardown();
        mql.removeEventListener("change", setup);
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initHero);
</script>
