---
import { readFileSync, existsSync, readdirSync } from "fs";
import { join } from "path";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { parseSections, renderSectionHtml } from "../../utils/case-study";
import "./_case-study.css";

export async function getStaticPaths() {
  const studies = await getCollection("caseStudies");
  return studies.map((study) => ({
    params: { id: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { title, shortDesc, tags, visual } = study.data;

// Load SVG diagrams from public/ and inline them so the page's Google Fonts apply
const diagramDir = join(process.cwd(), "public/case-studies", study.id);
const diagrams: Record<string, string> = {};
if (existsSync(diagramDir)) {
  for (const file of readdirSync(diagramDir).filter((f) => f.endsWith(".svg"))) {
    diagrams[file.replace(".svg", "")] = readFileSync(join(diagramDir, file), "utf-8");
  }
}

const allSections = parseSections(study.body);
const overviewSection = allSections.find((s) => s.heading === "Overview");
const accordionSections = allSections.filter((s) => s.heading !== "Overview");
---

<BaseLayout title={`${title} — Arkaes`} description={shortDesc}>
  <article class="cs-page">

    <header class="cs-hero">
      <div class="cs-hero-visual">
        {visual === "virtual-home" && (
          <div
            class="thumb-vhome thumb-vhome--hero"
            style={`view-transition-name: cs-thumb-${study.id};`}
          >
            <div class="thumb-vhome-frame">
              <div class="thumb-vhome-shared"></div>
              <div class="thumb-vhome-split">
                <div class="thumb-vhome-panel"></div>
                <div class="thumb-vhome-panel"></div>
              </div>
            </div>
          </div>
        )}
        {visual === "virtual-home-tv" && (
          <div
            class="thumb-vhome-tv thumb-vhome-tv--hero"
            style={`view-transition-name: cs-thumb-${study.id};`}
          >
            <div class="thumb-tv-screen">
              <div class="thumb-tv-topbar">
                <div class="thumb-tv-tab thumb-tv-tab--active"></div>
                <div class="thumb-tv-tab"></div>
                <div class="thumb-tv-tab"></div>
              </div>
              <div class="thumb-tv-grid">
                <div class="thumb-tv-card"></div>
                <div class="thumb-tv-card thumb-tv-card--focused"></div>
                <div class="thumb-tv-card"></div>
                <div class="thumb-tv-card"></div>
                <div class="thumb-tv-card"></div>
                <div class="thumb-tv-card"></div>
              </div>
            </div>
          </div>
        )}
      </div>

      <div class="cs-hero-meta">
        <div class="cs-hero-eyebrow">Case Study</div>
        <div class="cs-hero-tags">
          {tags.map((tag) => <ark-badge variant="pill">{tag}</ark-badge>)}
        </div>
        <h1 class="cs-hero-title">{title}</h1>
      </div>
    </header>

    {overviewSection && (
      <section class="cs-overview-section">
        <div class="cs-overview-inner">
          <div class="cs-overview-label">Overview</div>
          <div
            class="cs-overview-body"
            set:html={renderSectionHtml(overviewSection.content, diagrams)}
          />
        </div>
      </section>
    )}

    <section class="cs-accordion-section">
      <div class="cs-accordion-inner">
        <ark-accordion>
          {accordionSections.map((section) => (
            <ark-accordion-item heading={section.heading}>
              <div
                class="cs-section-content"
                set:html={renderSectionHtml(section.content, diagrams)}
              />
            </ark-accordion-item>
          ))}
        </ark-accordion>
      </div>
    </section>

    <div class="cs-back">
      <a href="/#case-studies" class="cs-back-link">&larr; Back to case studies</a>
    </div>

  </article>
</BaseLayout>
