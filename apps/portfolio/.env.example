# Copy to `.env` for local dev, and set the same vars in your Vercel project.
# Server-only — never expose these to the client (no PUBLIC_ prefix).

# Required: OpenAI API key used by the /api/chat (Arkhe) endpoint.
OPENAI_API_KEY=

# Optional: override the chat model (defaults to gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

# Optional: lock the chat endpoint to specific origins (comma-separated).
# When unset, only obvious cross-site requests are rejected. Leave unset for
# local dev / Vercel previews.
# CHAT_ALLOWED_ORIGINS=https://arkaes.dev,https://www.arkaes.dev
