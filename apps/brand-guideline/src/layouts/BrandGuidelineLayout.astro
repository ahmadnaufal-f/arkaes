---
import Analytics from "@vercel/analytics/astro";
import "../styles/brand-guideline.css";

interface Props {
  description?: string;
  title?: string;
}

const {
  description = "Arkaes brand identity guidelines for color, typography, logo usage, voice, digital touchpoints, and brand integrity.",
  title = "Arkaes Brand Guidelines",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#8f554d" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=JetBrains+Mono:wght@400;500;700&family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
    <Analytics />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import "@arkaes/ui/register/ark-badge";
      import "@arkaes/ui/register/ark-hero";
      import "@arkaes/ui/register/ark-navigation";
      import { enableArkCursor } from "@arkaes/ui/components/ark-cursor";

      // Custom cursor — the component owns the arrow/label chip, native-cursor
      // hiding, hover detection, and capability gating. The extra selectors
      // tint the arrow over this site's decorative interactive elements.
      enableArkCursor({
        interactiveSelectors: [
          ".swatch",
          ".pillar",
          ".pos-item",
          ".platform-card",
          ".tone-attr",
          ".toc-item",
        ],
      });
    </script>
  </body>
</html>
